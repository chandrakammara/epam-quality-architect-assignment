# Copy this file to `.env` in the same folder and fill in real values.
# Never commit the real `.env` file or real credentials.

# Loopback address of the InvenTree instance under test. Deliberately a
# literal IP, not "inventree.localhost" (which automation/ui's BASE_URL
# uses): Playwright's APIRequestContext resolves hosts via Node's
# dns.lookup, which - unlike browsers/curl - does not always special-case
# "*.localhost" as loopback per RFC 6761 (confirmed live: ENOTFOUND on
# this environment).
BASE_URL=http://127.0.0.1

# Virtual host the reverse proxy in front of InvenTree routes on. Sent as
# an explicit `Host` header on every request so it reaches the real app
# instead of the proxy's non-matching-host fallback.
HOST_HEADER=inventree.localhost

# Credentials for a valid InvenTree user account with Part
# view/add/change/delete permissions.
INVENTREE_USERNAME=your-username
INVENTREE_PASSWORD=your-password
